import java.util.*;
public class Sol{
    public static void main(String args[]){
        Scanner sc=new Scanner(System.in);
        String s=sc.nextLine().toLowerCase();
        int n=s.length();
        int l=0,r=n-1;
        while(l<r){
            if(s.charAt(l) != s.charAt(r)){
                System.out.print("Not a Palindrome");
                return;
            }
            l++;
            r--;
        }
        System.out.print("Palindrome");
    }
}
