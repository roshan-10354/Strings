
import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) 
    {
        Scanner sc=new Scanner(System.in);
        String s=sc.nextLine();
        char arr[]=s.toCharArray();
        int m=arr.length;
        int l=0,r=m-1;
        while(l<r){
                char t=arr[l];
                arr[l]=arr[r];
                arr[r]=t;
                l++;
                r--;
            }
            System.out.print(arr);
    }
}
