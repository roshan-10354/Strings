import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        String s[]=sc.nextLine().split(" ");
        String a=s[0];
        for(int i=1;i<s.length;i++){
            if(s[i].length() > a.length()){
                a=s[i];
            }
        }
        System.out.print(a);
    }
}
